# Database
DATABASE_URL=sqlite+aiosqlite:///./flowshift.db
# Production: DATABASE_URL=postgresql+asyncpg://user:pass@host/flowshift

# SolarEdge (optional — leave blank if using local API or no solar)
SOLAREDGE_SITE_ID=
SOLAREDGE_API_KEY=

# BPA grid data (Seattle MVP) — no key required, but set base URL if needed
BPA_API_BASE_URL=https://transmission.bpa.gov/business/operations/Wind/baltwg.txt

# EIA (US expansion) — get free key at api.eia.gov
EIA_API_KEY=

# Environment
ENV=development
SECRET_KEY=change-me-in-production
