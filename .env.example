# Database
DATABASE_URL=sqlite+aiosqlite:///./flowshift.db
# Production: DATABASE_URL=postgresql+asyncpg://user:pass@host/flowshift

# SolarEdge (optional — leave blank if using local API or no solar)
SOLAREDGE_SITE_ID=
SOLAREDGE_API_KEY=

# BPA grid data (Seattle MVP) — no key required, but set base URL if needed
BPA_API_BASE_URL=https://transmission.bpa.gov/business/operations/Wind/baltwg.txt

# EIA (US expansion) — get free key at api.eia.gov
EIA_API_KEY=

# NREL (rate data) — get free key at https://developer.nlr.gov/signup/
NREL_API_KEY=

# Environment
ENV=development
SECRET_KEY=change-me-in-production
FRONTEND_URL=http://localhost:3000

# CORS — comma-separated list of allowed browser origins (no wildcards when credentials are used)
# Local dev default is http://localhost:3000. In production set to your frontend URL(s).
# Example: CORS_ORIGINS=https://flowshift.app,https://www.flowshift.app
CORS_ORIGINS=http://localhost:3000

# Session
SESSION_MAX_AGE_DAYS=30

# OAuth — Google (https://console.developers.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth — Apple (https://developer.apple.com/)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Magic link email — Resend (https://resend.com, free tier: 100 emails/day)
RESEND_API_KEY=
MAGIC_LINK_FROM_EMAIL=noreply@flowshift.app
